#!/bin/sh
set -eu

app_class="chrome-web.whatsapp.com__-Default"
profile_dir="$HOME/.local/share/whatsapp-web-chromium"
app_url="https://web.whatsapp.com"
chromium_extra_args=""
extension_dir="$HOME/.local/share/whatsapp-web-extension"
native_host_name="com.shaka.wwdt_brave"
legacy_extension_id="pegillnacjhfdokcfpieidpbbknaaghh"
extension_id="cdfllcdhkhafoplikbchoedlapjbfakn"
extension_args=""
start_hidden="0"
if [ -d "$extension_dir" ]; then
	extension_args="--disable-extensions-except=${extension_dir} --load-extension=${extension_dir}"
fi
mkdir -p "$profile_dir" "$profile_dir/notification-sounds"

install_native_messaging_host() {
	native_host_source=""
	for candidate in \
		"$HOME/.local/share/chromium/NativeMessagingHosts/${native_host_name}.json" \
		"$HOME/.dotfiles/local/share/chromium/NativeMessagingHosts/${native_host_name}.json"
	do
		if [ -f "$candidate" ]; then
			native_host_source="$candidate"
			break
		fi
	done

	[ -n "$native_host_source" ] || return 0

	for target_dir in \
		"${XDG_CONFIG_HOME:-$HOME/.config}/chromium/NativeMessagingHosts" \
		"${profile_dir}/NativeMessagingHosts"
	do
		target_file="${target_dir}/${native_host_name}.json"
		mkdir -p "$target_dir"
		if ! cmp -s "$native_host_source" "$target_file"; then
			tmp_file="${target_file}.wwdt.$$"
			cp "$native_host_source" "$tmp_file"
			mv "$tmp_file" "$target_file"
		fi
	done
}

case "${WHATSAPP_DEVTOOLS:-0}" in
	1|true|yes|on)
		app_url="https://web.whatsapp.com/?wwdt-devtools=1"
		chromium_extra_args="--auto-open-devtools-for-tabs"
		;;
esac

case "${WHATSAPP_START_HIDDEN:-0}" in
	1|true|yes|on)
		start_hidden="1"
		;;
esac

runtime_dir="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
socket="${runtime_dir}/hypr/${HYPRLAND_INSTANCE_SIGNATURE:-}/.socket.sock"

is_hyprland() {
	[ -n "${HYPRLAND_INSTANCE_SIGNATURE:-}" ] || [ "${XDG_CURRENT_DESKTOP:-}" = "Hyprland" ]
}

hypr_query() {
	printf '%s' "$1" | nc -U "$socket"
}

hypr_dispatch() {
	hyprctl dispatch "$@" >/dev/null
}

cleanup_legacy_extension_state() {
	default_dir="${profile_dir}/Default"

	if ! command -v jq >/dev/null 2>&1; then
		return
	fi

	for state_file in "${default_dir}/Preferences" "${default_dir}/Secure Preferences"; do
		[ -f "${state_file}" ] || continue

		tmp_file="${state_file}.wwdt.$$"
		if jq --arg old "${legacy_extension_id}" '
			if (.extensions? and .extensions.settings?) then
				.extensions.settings |= with_entries(select(.key != $old))
			else
				.
			end
			| if (.protection? and .protection.macs? and .protection.macs.extensions? and .protection.macs.extensions.settings?) then
				.protection.macs.extensions.settings |= with_entries(select(.key != $old))
			else
				.
			end
			| if (.protection? and .protection.macs? and .protection.macs.extensions? and .protection.macs.extensions.settings_encrypted_hash?) then
				.protection.macs.extensions.settings_encrypted_hash |= with_entries(select(.key != $old))
			else
				.
			end
		' "${state_file}" > "${tmp_file}"; then
			mv "${tmp_file}" "${state_file}"
		else
			rm -f "${tmp_file}"
		fi
	done

	rm -rf "${default_dir}/Local Extension Settings/${legacy_extension_id}"
}

cleanup_extension_runtime_cache() {
	default_dir="${profile_dir}/Default"
	manifest_file="${extension_dir}/manifest.json"
	preferences_file="${default_dir}/Preferences"

	if ! command -v jq >/dev/null 2>&1 || [ ! -f "$manifest_file" ] || [ ! -f "$preferences_file" ]; then
		return
	fi

	manifest_version="$(jq -r '.version // empty' "$manifest_file" 2>/dev/null || printf '')"
	registered_version="$(jq -r --arg id "$extension_id" '.extensions.settings[$id].service_worker_registration_info.version // empty' "$preferences_file" 2>/dev/null || printf '')"

	if [ -z "$manifest_version" ] || [ "$registered_version" = "$manifest_version" ]; then
		return
	fi

	for state_file in "${default_dir}/Preferences" "${default_dir}/Secure Preferences"; do
		[ -f "$state_file" ] || continue

		tmp_file="${state_file}.wwdt.$$"
		if jq --arg id "$extension_id" '
			if (.extensions? and .extensions.settings? and .extensions.settings[$id]?) then
				del(.extensions.settings[$id].service_worker_registration_info)
				| .extensions.settings[$id].has_started_service_worker = false
			else
				.
			end
		' "$state_file" > "$tmp_file"; then
			mv "$tmp_file" "$state_file"
		else
			rm -f "$tmp_file"
		fi
	done

	rm -rf "${default_dir}/Extension Scripts" "${default_dir}/Service Worker/ScriptCache"
}

launch_chromium() {
	if command -v setsid >/dev/null 2>&1; then
		setsid -f /usr/bin/chromium \
			--app="${app_url}" \
			--user-data-dir="${profile_dir}" \
			--class=WhatsAppWeb \
			--name=WhatsAppWeb \
			--no-first-run \
			--disable-sync \
			--disable-default-apps \
			--disable-background-mode \
			${extension_args} \
			${chromium_extra_args} \
			--disable-features=Translate,OptimizationGuideModelDownloading,MediaRouter >/dev/null 2>&1
	else
		nohup /usr/bin/chromium \
			--app="${app_url}" \
			--user-data-dir="${profile_dir}" \
			--class=WhatsAppWeb \
			--name=WhatsAppWeb \
			--no-first-run \
			--disable-sync \
			--disable-default-apps \
			--disable-background-mode \
			${extension_args} \
			${chromium_extra_args} \
			--disable-features=Translate,OptimizationGuideModelDownloading,MediaRouter >/dev/null 2>&1 &
	fi
}

wait_for_client_address() {
	attempt=0
	while [ "$attempt" -lt 80 ]; do
		clients_json="$(hypr_query 'j/clients' 2>/dev/null || printf '[]')"
		address="$(printf '%s' "$clients_json" | jq -r --arg cls "$app_class" 'map(select(.class == $cls))[0].address // empty')"
		if [ -n "$address" ]; then
			printf '%s\n' "$address"
			return 0
		fi
		sleep 0.1
		attempt=$((attempt + 1))
	done
	return 1
}

if [ -S "$socket" ] && command -v nc >/dev/null 2>&1 && command -v jq >/dev/null 2>&1 && is_hyprland; then
	clients_json="$(hypr_query 'j/clients' 2>/dev/null || printf '[]')"
	client_json="$(printf '%s' "$clients_json" | jq -c --arg cls "$app_class" 'map(select(.class == $cls))[0] // empty')"
	if [ -n "$client_json" ]; then
		address="$(printf '%s' "$client_json" | jq -r '.address')"
		if [ -n "$chromium_extra_args" ]; then
			hypr_dispatch closewindow "address:${address}" || true
			attempt=0
			while [ "$attempt" -lt 30 ]; do
				sleep 0.1
				clients_json="$(hypr_query 'j/clients' 2>/dev/null || printf '[]')"
				if ! printf '%s' "$clients_json" | jq -e --arg cls "$app_class" 'any(.[]; .class == $cls)' >/dev/null; then
					client_json=""
					break
				fi
				attempt=$((attempt + 1))
			done
		fi
	fi
	if [ -n "$client_json" ]; then
		workspace="$(printf '%s' "$client_json" | jq -r '.workspace.name // ""')"
		active_workspace="$(hypr_query 'j/activeworkspace' 2>/dev/null | jq -r '.name // ""')"

		if [ "$start_hidden" = "1" ]; then
			hypr_dispatch movetoworkspacesilent "special:whatsapp,address:${address}" || true
			exit 0
		fi

		if [ "$workspace" = "special:whatsapp" ] && [ -n "$active_workspace" ]; then
			hypr_dispatch movetoworkspace "${active_workspace},address:${address}" || true
		elif [ -n "$workspace" ] && [ "$workspace" != "$active_workspace" ]; then
			hypr_dispatch workspace "$workspace" || true
			sleep 0.05
		fi

		hypr_dispatch focuswindow "address:${address}" || \
			hypr_dispatch focuswindow "class:${app_class}" || true
		exit 0
	fi
elif command -v hyprctl >/dev/null 2>&1 && is_hyprland; then
	if hyprctl clients 2>/dev/null | grep -Fq "class: ${app_class}"; then
		if [ "$start_hidden" = "1" ]; then
			hyprctl dispatch movetoworkspacesilent "special:whatsapp,class:${app_class}" >/dev/null 2>&1 || true
			exit 0
		fi
		hyprctl dispatch focuswindow "class:${app_class}" >/dev/null 2>&1 || true
		exit 0
	fi
fi

install_native_messaging_host
cleanup_legacy_extension_state
cleanup_extension_runtime_cache
launch_chromium

if [ "$start_hidden" = "0" ] && [ -S "$socket" ] && command -v nc >/dev/null 2>&1 && command -v jq >/dev/null 2>&1 && is_hyprland; then
	if address="$(wait_for_client_address)"; then
		active_workspace="$(hypr_query 'j/activeworkspace' 2>/dev/null | jq -r '.name // ""')"
		if [ -n "$active_workspace" ]; then
			hypr_dispatch movetoworkspace "${active_workspace},address:${address}" || true
		fi
		hypr_dispatch focuswindow "address:${address}" || \
			hypr_dispatch focuswindow "class:${app_class}" || true
	fi
fi
