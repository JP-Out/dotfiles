#!/bin/sh
set -eu

app_class="chrome-web.whatsapp.com__-Default"
profile_dir="$HOME/.local/share/whatsapp-web-chromium"
app_url="https://web.whatsapp.com"
chromium_extra_args=""
extension_dir="$HOME/.local/share/whatsapp-web-extension"
extension_args=""
if [ -d "$extension_dir" ]; then
	extension_args="--disable-extensions-except=${extension_dir} --load-extension=${extension_dir}"
fi
mkdir -p "$profile_dir" "$profile_dir/notification-sounds"

case "${WHATSAPP_DEVTOOLS:-0}" in
	1|true|yes|on)
		app_url="https://web.whatsapp.com/?wwdt-devtools=1"
		chromium_extra_args="--auto-open-devtools-for-tabs"
		;;
esac

runtime_dir="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
socket="${runtime_dir}/hypr/${HYPRLAND_INSTANCE_SIGNATURE:-}/.socket.sock"

is_hyprland() {
	[ -n "${HYPRLAND_INSTANCE_SIGNATURE:-}" ] || [ "${XDG_CURRENT_DESKTOP:-}" = "Hyprland" ]
}

hypr_query() {
	printf '%s' "$1" | nc -U "$socket"
}

hypr_dispatch() {
	hyprctl dispatch "$@" >/dev/null
}

if [ -S "$socket" ] && command -v nc >/dev/null 2>&1 && command -v jq >/dev/null 2>&1 && is_hyprland; then
	clients_json="$(hypr_query 'j/clients' 2>/dev/null || printf '[]')"
	client_json="$(printf '%s' "$clients_json" | jq -c --arg cls "$app_class" 'map(select(.class == $cls))[0] // empty')"
	if [ -n "$client_json" ]; then
		address="$(printf '%s' "$client_json" | jq -r '.address')"
		if [ -n "$chromium_extra_args" ]; then
			hypr_dispatch closewindow "address:${address}" || true
			attempt=0
			while [ "$attempt" -lt 30 ]; do
				sleep 0.1
				clients_json="$(hypr_query 'j/clients' 2>/dev/null || printf '[]')"
				if ! printf '%s' "$clients_json" | jq -e --arg cls "$app_class" 'any(.[]; .class == $cls)' >/dev/null; then
					client_json=""
					break
				fi
				attempt=$((attempt + 1))
			done
		fi
	fi
	if [ -n "$client_json" ]; then
		workspace="$(printf '%s' "$client_json" | jq -r '.workspace.name // ""')"
		active_workspace="$(hypr_query 'j/activeworkspace' 2>/dev/null | jq -r '.name // ""')"

		if [ "$workspace" = "special:whatsapp" ] && [ -n "$active_workspace" ]; then
			hypr_dispatch movetoworkspace "${active_workspace},address:${address}" || true
		elif [ -n "$workspace" ] && [ "$workspace" != "$active_workspace" ]; then
			hypr_dispatch workspace "$workspace" || true
			sleep 0.05
		fi

		hypr_dispatch focuswindow "address:${address}" || \
			hypr_dispatch focuswindow "class:${app_class}" || true
		exit 0
	fi
elif command -v hyprctl >/dev/null 2>&1 && is_hyprland; then
	if hyprctl clients 2>/dev/null | grep -Fq "class: ${app_class}"; then
		hyprctl dispatch focuswindow "class:${app_class}" >/dev/null 2>&1 || true
		exit 0
	fi
fi

if command -v setsid >/dev/null 2>&1; then
	setsid -f /usr/bin/chromium \
		--app="${app_url}" \
		--user-data-dir="${profile_dir}" \
		--class=WhatsAppWeb \
		--name=WhatsAppWeb \
		--no-first-run \
		--disable-sync \
		--disable-default-apps \
		--disable-background-mode \
		${extension_args} \
		${chromium_extra_args} \
		--disable-features=Translate,OptimizationGuideModelDownloading,MediaRouter >/dev/null 2>&1
else
	nohup /usr/bin/chromium \
		--app="${app_url}" \
		--user-data-dir="${profile_dir}" \
		--class=WhatsAppWeb \
		--name=WhatsAppWeb \
		--no-first-run \
		--disable-sync \
		--disable-default-apps \
		--disable-background-mode \
		${extension_args} \
		${chromium_extra_args} \
		--disable-features=Translate,OptimizationGuideModelDownloading,MediaRouter >/dev/null 2>&1 &
fi
