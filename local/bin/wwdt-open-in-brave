#!/usr/bin/env python3
import json
import os
import shutil
import struct
import subprocess
import sys
from datetime import datetime, timezone


LOG_PATH = os.path.expanduser("~/.local/state/whatsapp-web-chromium/link-open.log")


def log_event(event, **data):
    try:
        os.makedirs(os.path.dirname(LOG_PATH), exist_ok=True)
        payload = {
            "timestamp": datetime.now(timezone.utc).isoformat(),
            "event": event,
            **data,
        }
        with open(LOG_PATH, "a", encoding="utf-8") as log_file:
            log_file.write(json.dumps(payload, ensure_ascii=False) + "\n")
    except Exception:
        pass


def find_browser():
    for candidate in ("brave", "brave-browser", "xdg-open"):
        path = shutil.which(candidate)
        if path:
            return path
    return None


def send_message(payload):
    encoded = json.dumps(payload).encode("utf-8")
    sys.stdout.buffer.write(struct.pack("<I", len(encoded)))
    sys.stdout.buffer.write(encoded)
    sys.stdout.buffer.flush()


def launch_url(url):
    browser = find_browser()
    if not browser:
        log_event("native-open-failed", url=url, error="No browser launcher found")
        return False, "No browser launcher found"

    if browser.endswith("/brave") or browser.endswith("/brave-browser"):
        command = [browser, "--new-tab", url]
    else:
        command = [browser, url]

    log_event("native-open-command", url=url, browser=browser, command=command)
    process = subprocess.Popen(
        command,
        stdin=subprocess.DEVNULL,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        start_new_session=True,
        close_fds=True,
    )
    log_event("native-open-spawned", url=url, browser=browser, pid=process.pid)
    return True, None


def read_native_message():
    raw_length = sys.stdin.buffer.read(4)
    if len(raw_length) != 4:
        return None

    message_length = struct.unpack("<I", raw_length)[0]
    payload = sys.stdin.buffer.read(message_length)
    if len(payload) != message_length:
        return None

    return json.loads(payload.decode("utf-8"))


def handle_url(url):
    if not isinstance(url, str) or not url.startswith(("http://", "https://")):
        log_event("native-invalid-url", url=url)
        return {"ok": False, "error": "Invalid URL"}

    ok, error = launch_url(url)
    if not ok:
      return {"ok": False, "error": error}
    return {"ok": True}


def handle_message(message):
    log_event("native-message", message=message)
    if isinstance(message, dict) and message.get("ping") is True:
        browser = find_browser()
        log_event("native-ping", browser=browser)
        return {"ok": browser is not None, "browser": browser}

    if not isinstance(message, dict):
        log_event("native-invalid-message", message=message)
        return {"ok": False, "error": "Invalid message"}

    if "log" in message:
        log_event("extension-log", payload=message.get("log"))
        return {"ok": True}

    return handle_url(message.get("url"))


def main():
    if len(sys.argv) == 3 and sys.argv[1] == "--url":
        payload = handle_url(sys.argv[2])
        print(json.dumps(payload))
        return 0 if payload.get("ok") else 1

    message = read_native_message()
    if message is None:
        return 1

    send_message(handle_message(message))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
